---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Capabilities from '../components/Capabilities.astro';
import Architecture from '../components/Architecture.astro';
import Security from '../components/Security.astro';
import SmartRouter from '../components/SmartRouter.astro';
import VoiceInteraction from '../components/VoiceInteraction.astro';
import BrainSection from '../components/BrainSection.astro';
import LocalFirst from '../components/LocalFirst.astro';
import BuddyShowcase from '../components/BuddyShowcase.astro';
import DesktopClient from '../components/DesktopClient.astro';
import CostTracking from '../components/CostTracking.astro';
import Comparison from '../components/Comparison.astro';
import ChannelWall from '../components/ChannelWall.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Scenarios from '../components/Scenarios.astro';
import QuickStart from '../components/QuickStart.astro';
import Community from '../components/Community.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <nav class="fixed top-0 left-0 right-0 z-50 bg-surface-975/70 backdrop-blur-xl border-b border-surface-800/30">
    <div class="section-container flex items-center justify-between h-16">
      <a href="#" class="flex items-center gap-2.5 text-surface-200 font-bold shrink-0">
        <svg class="w-7 h-7" viewBox="0 0 512 512" fill="none">
          <defs>
            <linearGradient id="navLogo" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#FF5A36"/>
              <stop offset="100%" stop-color="#FF8C66"/>
            </linearGradient>
          </defs>
          <rect x="180" y="160" width="44" height="180" rx="12" fill="url(#navLogo)"/>
          <rect x="180" y="296" width="140" height="44" rx="12" fill="url(#navLogo)"/>
          <line x1="224" y1="200" x2="340" y2="170" stroke="url(#navLogo)" stroke-width="16" stroke-linecap="round"/>
          <line x1="224" y1="230" x2="320" y2="210" stroke="url(#navLogo)" stroke-width="12" stroke-linecap="round"/>
          <line x1="224" y1="260" x2="290" y2="248" stroke="url(#navLogo)" stroke-width="8" stroke-linecap="round"/>
        </svg>
        Liri
      </a>

      <!-- 桌面端导航链接 -->
      <div class="hidden md:flex items-center gap-5 text-sm">
        <a href="#capabilities" class="text-surface-400 hover:text-surface-200 transition-colors">核心能力</a>
        <a href="#architecture" class="text-surface-400 hover:text-surface-200 transition-colors">架构</a>
        <a href="#security" class="text-surface-400 hover:text-surface-200 transition-colors">安全</a>
        <a href="#smart-router" class="text-surface-400 hover:text-surface-200 transition-colors">路由</a>
        <a href="#voice" class="text-surface-400 hover:text-surface-200 transition-colors">语音</a>
        <a href="#brain" class="text-surface-400 hover:text-surface-200 transition-colors">外脑</a>
        <a href="#desktop" class="text-surface-400 hover:text-surface-200 transition-colors">桌面</a>
        <a href="#cost" class="text-surface-400 hover:text-surface-200 transition-colors">成本</a>
        <a href="#ecosystem" class="text-surface-400 hover:text-surface-200 transition-colors">市场</a>
        <a href="#quickstart" class="text-surface-400 hover:text-surface-200 transition-colors">开始</a>
      </div>

      <!-- 移动端汉堡按钮 -->
      <button id="menu-btn" class="md:hidden p-2 rounded-lg text-surface-400 hover:text-surface-200 hover:bg-surface-800/50 transition-colors" aria-label="打开菜单">
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- 移动端菜单面板 -->
    <div id="mobile-menu" class="md:hidden hidden fixed inset-x-0 top-16 bottom-0 bg-surface-975/95 backdrop-blur-2xl border-t border-surface-800/30 overflow-y-auto">
      <div class="section-container py-6 space-y-1">
        <a href="#capabilities" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">核心能力</a>
        <a href="#architecture" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">架构</a>
        <a href="#security" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">安全</a>
        <a href="#smart-router" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">路由</a>
        <a href="#voice" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">语音</a>
        <a href="#brain" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">外脑</a>
        <a href="#desktop" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">桌面</a>
        <a href="#cost" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">成本</a>
        <a href="#ecosystem" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">市场</a>
        <a href="#quickstart" class="block px-4 py-3 rounded-xl text-surface-300 hover:text-surface-100 hover:bg-surface-800/50 transition-colors text-base font-medium" onclick="closeMenu()">开始</a>
      </div>
    </div>
  </nav>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    function toggleMenu() {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
      document.body.style.overflow = isOpen ? '' : 'hidden';
    }

    function closeMenu() {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', toggleMenu);
  </script>

  <main>
    <Hero />
    <About />
    <Capabilities />
    <Architecture />
    <Security />
    <SmartRouter />
    <VoiceInteraction />
    <BrainSection />
    <LocalFirst />
    <BuddyShowcase />
    <DesktopClient />
    <CostTracking />
    <Comparison />
    <ChannelWall />
    <Ecosystem />
    <Scenarios />
    <QuickStart />
    <Community />
  </main>

  <Footer />
</Layout>
