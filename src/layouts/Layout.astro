---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Liri — 你的 AI 私人助手', description = 'Liri 是一个运行在终端中的 AI 智能助手。智能对话、工具调用、多平台接入、安全可控。' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Liri,AI助手,AI Agent,命令行工具,智能助手,玲珑鸟" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://openliri.com" />
    <meta property="og:image" content="https://openliri.com/og-image.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/png" href="/logo.png" />

    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
