---
// 任务类型数据
const taskTypes = [
  { name: '编码', icon: '💻', desc: '代码生成/调试/审查', color: 'text-green-400' },
  { name: '写作', icon: '✍️', desc: '文档/文案/翻译', color: 'text-blue-400' },
  { name: '分析', icon: '📊', desc: '数据分析/推理/规划', color: 'text-purple-400' },
  { name: '工具', icon: '🔧', desc: '文件/搜索/系统操作', color: 'text-amber-400' },
  { name: '翻译', icon: '🌐', desc: '多语言翻译/本地化', color: 'text-cyan-400' },
  { name: '搜索', icon: '🔍', desc: 'Web 搜索/信息检索', color: 'text-rose-400' },
  { name: '创意', icon: '🎨', desc: '头脑风暴/设计/构思', color: 'text-pink-400' },
  { name: '闲聊', icon: '💬', desc: '日常对话/通用交流', color: 'text-surface-400' },
];

// 决策层数据
const layers = [
  { name: 'L1: 成本筛选', desc: '优先选择费用最低的可用模型', color: 'bg-green-500/10 border-green-500/20' },
  { name: 'L2: 能力匹配', desc: '任务类型与模型专长对齐', color: 'bg-brand-500/10 border-brand-500/20' },
  { name: 'L3: 延迟评估', desc: '选择响应速度最快的模型', color: 'bg-cyan-500/10 border-cyan-500/20' },
  { name: 'L4: 本地可用', desc: '本地模型优先，数据不离开设备', color: 'bg-amber-500/10 border-amber-500/20' },
  { name: 'L5: 用户偏好', desc: '尊重用户手动选择的模型', color: 'bg-purple-500/10 border-purple-500/20' },
];

// 回退链数据
const fallbackChain = [
  { name: '首选', model: 'GPT-4o / Claude 4', status: 'primary' },
  { name: '回退 1', model: 'DeepSeek-V3', status: 'fallback' },
  { name: '回退 2', model: 'Gemini 2.5 Pro', status: 'fallback' },
  { name: '回退 3', model: 'Qwen-Max', status: 'fallback' },
  { name: '降级', model: '本地 Ollama 模型', status: 'fallback' },
];
---

<section id="smart-router" class="section-padding relative">
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 via-surface-975 to-surface-950 pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-brand-500/3 blur-3xl rounded-full pointer-events-none"></div>

  <div class="section-container relative z-10">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">智能路由</span>
    </h2>
    <p class="text-surface-400 text-center mb-12 max-w-3xl mx-auto">
      不是所有模型都适合所有任务。Liri 自动帮你选择最快、最省、最准确的模型
    </p>

    <!-- 8 种任务类型 -->
    <div class="max-w-4xl mx-auto mb-12">
      <h3 class="text-sm font-mono text-surface-500 text-center mb-5">自动识别 8 种任务类型</h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {taskTypes.map((t) => (
          <div class="glass-card p-4 text-center hover:border-brand-500/30 transition-all duration-300">
            <div class="text-2xl mb-1">{t.icon}</div>
            <div class={`text-sm font-semibold ${t.color}`}>{t.name}</div>
            <div class="text-xs text-surface-500 mt-1">{t.desc}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- 5 层决策管线 -->
    <div class="max-w-3xl mx-auto mb-12">
      <h3 class="text-sm font-mono text-surface-500 text-center mb-5">5 层决策管线</h3>
      <div class="space-y-2">
        {layers.map((layer, i) => (
          <div>
            <div class={`p-4 rounded-xl ${layer.color} border`}>
              <div class="flex items-center gap-3">
                <span class="text-xs font-mono text-surface-500 bg-surface-800/60 px-2 py-0.5 rounded">{i + 1}</span>
                <span class="text-sm font-semibold text-surface-200">{layer.name}</span>
                <span class="text-xs text-surface-500 ml-auto">{layer.desc}</span>
              </div>
            </div>
            {i < layers.length - 1 && (
              <div class="flex justify-center py-1">
                <svg class="w-3 h-3 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- 供应商回退链 -->
    <div class="max-w-3xl mx-auto glass-card p-5 sm:p-6 border-amber-500/20">
      <h3 class="text-sm font-mono text-surface-500 text-center mb-4">供应商回退链</h3>
      <p class="text-surface-400 text-xs text-center mb-4">主模型不可用 → 自动回退 → 降级不中断</p>
      <!-- 桌面端：横向排列 -->
      <div class="hidden sm:flex flex-wrap items-center justify-center gap-2">
        {fallbackChain.map((f, i) => (
          <>
            <div class={`px-4 py-2 rounded-xl text-sm font-mono ${
              f.status === 'primary'
                ? 'bg-brand-500/10 border border-brand-500/20 text-brand-300'
                : 'bg-surface-800/40 border border-surface-800/50 text-surface-400'
            }`}>
              {f.model}
            </div>
            {i < fallbackChain.length - 1 && (
              <svg class="w-4 h-4 text-surface-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            )}
          </>
        ))}
      </div>
      <!-- 移动端：纵向排列 -->
      <div class="sm:hidden space-y-2">
        {fallbackChain.map((f, i) => (
          <div class="flex items-center gap-2">
            {i > 0 && (
              <svg class="w-3 h-3 text-surface-600 shrink-0 -ml-0.5 rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
              </svg>
            )}
            <div class={`flex-1 px-4 py-2 rounded-xl text-sm font-mono ${
              f.status === 'primary'
                ? 'bg-brand-500/10 border border-brand-500/20 text-brand-300'
                : 'bg-surface-800/40 border border-surface-800/50 text-surface-400'
            }`}>
              <span class="text-xs text-surface-500 mr-2 font-mono">{f.name}</span>
              {f.model}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
