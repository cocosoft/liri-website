---
---

<section id="architecture" class="section-padding relative">
  <div class="section-container">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">架构概览</span>
    </h2>
    <p class="text-surface-400 text-center mb-16 max-w-2xl mx-auto">
      五层架构设计，40+ 模块化子系统，各司其职
    </p>

    <div class="max-w-4xl mx-auto space-y-3">
      <!-- 用户界面层 -->
      <div class="glass-card p-5 text-center group hover:border-brand-500/30 transition-all duration-300">
        <div class="text-xs font-mono text-surface-500 mb-2">用户界面层</div>
        <div class="flex flex-wrap justify-center gap-2">
          {['REPL', 'CLI', 'MCP', '渠道 (26+)'].map((item) => (
            <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-sm font-mono border border-surface-700/50">
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- 连接箭头 -->
      <div class="flex justify-center">
        <svg class="w-5 h-5 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>

      <!-- 网关层 -->
      <div class="glass-card p-5 text-center group hover:border-brand-500/30 transition-all duration-300">
        <div class="text-xs font-mono text-surface-500 mb-2">网关层</div>
        <div class="flex flex-wrap justify-center gap-2">
          {['消息路由', '协议转换', '认证'].map((item) => (
            <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-sm font-mono border border-surface-700/50">
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- 连接箭头 -->
      <div class="flex justify-center">
        <svg class="w-5 h-5 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>

      <!-- AI 引擎层 -->
      <div class="glass-card p-5 text-center group hover:border-brand-500/30 transition-all duration-300">
        <div class="text-xs font-mono text-surface-500 mb-2">AI 引擎层</div>
        <div class="flex flex-wrap justify-center gap-2">
          {['多 Provider', '模型路由', '成本追踪', '故障切换'].map((item) => (
            <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-sm font-mono border border-surface-700/50">
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- 连接箭头 -->
      <div class="flex justify-center">
        <svg class="w-5 h-5 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>

      <!-- 核心服务层 -->
      <div class="glass-card p-5 text-center group hover:border-brand-500/30 transition-all duration-300">
        <div class="text-xs font-mono text-surface-500 mb-2">核心服务层</div>
        <div class="flex flex-wrap justify-center gap-2">
          {['工具系统', '记忆系统', '安全系统', '任务引擎', '权限控制', '插件管理', '会话管理', '事件总线'].map((item) => (
            <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-sm font-mono border border-surface-700/50">
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- 连接箭头 -->
      <div class="flex justify-center">
        <svg class="w-5 h-5 text-surface-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>

      <!-- 基础设施层 -->
      <div class="glass-card p-5 text-center border-brand-500/20 group hover:border-brand-500/40 transition-all duration-300">
        <div class="text-xs font-mono text-surface-500 mb-2">基础设施层</div>
        <div class="flex flex-wrap justify-center gap-2">
          {['SQLite', '缓存', '日志', '监控', '原生模块 (Rust)'].map((item) => (
            <span class="px-3 py-1 rounded-lg bg-brand-500/10 text-brand-300 text-sm font-mono border border-brand-500/20">
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
