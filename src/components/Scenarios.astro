---
interface Scenario {
  icon: string;
  title: string;
  description: string;
  tag: string;
}

const scenarios: Scenario[] = [
  {
    icon: '💻',
    title: '命令行助手',
    description: '在终端里直接对话，执行命令，管理项目。无需离开命令行，Liri 就是你的编程搭档。',
    tag: '开发者',
  },
  {
    icon: '👥',
    title: '团队协作',
    description: '接入 Slack、飞书等平台，自动处理任务、查询数据、通知告警，让团队效率翻倍。',
    tag: '团队',
  },
  {
    icon: '📚',
    title: '个人知识库',
    description: '记录笔记、自动整理、语义搜索。Liri 帮你构建第二大脑，知识永不丢失。',
    tag: '个人',
  },
  {
    icon: '⚡',
    title: '自动化工作流',
    description: '定时任务、代码审查、部署流水线。让重复的工作自动化，聚焦真正重要的事。',
    tag: 'DevOps',
  },
];
---

<section id="scenarios" class="section-padding relative">
  <div class="section-container">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">使用场景</span>
    </h2>
    <p class="text-surface-400 text-center mb-16 max-w-2xl mx-auto">
      无论你是开发者、团队负责人，还是效率追求者，Liri 都能帮到你
    </p>

    <div class="space-y-6">
      {scenarios.map((scene, index) => (
        <div
          class="glass-card p-6 sm:p-8 flex flex-col sm:flex-row items-start gap-6 group hover:border-brand-500/30 transition-all duration-500"
          style={`animation: fade-in-up .6s ease-out ${index * 0.15}s both;`}
        >
          <div class="text-4xl shrink-0 w-14 h-14 flex items-center justify-center rounded-xl bg-surface-800/50 group-hover:bg-brand-500/10 transition-colors duration-300">
            {scene.icon}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="text-xl font-bold text-surface-100">{scene.title}</h3>
              <span class="px-2.5 py-0.5 rounded-full text-xs font-mono bg-brand-500/10 text-brand-400 border border-brand-500/20">
                {scene.tag}
              </span>
            </div>
            <p class="text-surface-400 leading-relaxed">{scene.description}</p>
          </div>
          <svg class="w-5 h-5 text-surface-600 group-hover:text-brand-400 transition-colors duration-300 hidden sm:block shrink-0 mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      ))}
    </div>
  </div>
</section>
