---
---

<section id="quickstart" class="section-padding relative">
  <div class="section-container">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">快速开始</span>
    </h2>
    <p class="text-surface-400 text-center mb-16 max-w-2xl mx-auto">
      一分钟上手，开启你的 AI 智能助手之旅
    </p>

    <div class="max-w-2xl mx-auto space-y-4">
      <!-- 步骤 1 -->
      <div class="glass-card p-6 group hover:border-brand-500/30 transition-all duration-300">
        <div class="flex items-center gap-4 mb-3">
          <span class="w-8 h-8 rounded-lg bg-brand-500/15 text-brand-400 font-mono text-sm flex items-center justify-center shrink-0">1</span>
          <h3 class="font-bold text-surface-100">安装依赖</h3>
        </div>
        <div class="relative">
          <div class="bg-surface-975 rounded-xl p-4 overflow-x-auto">
            <code class="text-sm font-mono text-surface-200">
              <span class="text-surface-500">$ </span>
              <span class="text-brand-300">cd</span> app && bun install
            </code>
          </div>
          <button class="absolute top-3 right-3 p-1.5 rounded-lg bg-surface-800 text-surface-400 hover:text-surface-200 hover:bg-surface-700 transition-colors" title="复制命令" onclick="navigator.clipboard?.writeText('cd app && bun install')">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
        </div>
      </div>

      <!-- 步骤 2 -->
      <div class="glass-card p-6 group hover:border-brand-500/30 transition-all duration-300">
        <div class="flex items-center gap-4 mb-3">
          <span class="w-8 h-8 rounded-lg bg-brand-500/15 text-brand-400 font-mono text-sm flex items-center justify-center shrink-0">2</span>
          <h3 class="font-bold text-surface-100">配置 API Key</h3>
        </div>
        <div class="relative">
          <div class="bg-surface-975 rounded-xl p-4 overflow-x-auto">
            <code class="text-sm font-mono text-surface-200">
              <span class="text-surface-500">$ </span>
              <span class="text-brand-300">cp</span> .env.example .env<br />
              <span class="text-surface-500">$ </span>
              <span class="text-surface-400"># 编辑 .env 填入你的 API Key</span>
            </code>
          </div>
          <button class="absolute top-3 right-3 p-1.5 rounded-lg bg-surface-800 text-surface-400 hover:text-surface-200 hover:bg-surface-700 transition-colors" title="复制命令" onclick="navigator.clipboard?.writeText('cp .env.example .env')">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
        </div>
      </div>

      <!-- 步骤 3 -->
      <div class="glass-card p-6 group hover:border-brand-500/30 transition-all duration-300">
        <div class="flex items-center gap-4 mb-3">
          <span class="w-8 h-8 rounded-lg bg-brand-500/15 text-brand-400 font-mono text-sm flex items-center justify-center shrink-0">3</span>
          <h3 class="font-bold text-surface-100">启动 Liri</h3>
        </div>
        <div class="relative">
          <div class="bg-surface-975 rounded-xl p-4 overflow-x-auto">
            <code class="text-sm font-mono text-surface-200">
              <span class="text-surface-500">$ </span>
              bun run dev
            </code>
          </div>
          <button class="absolute top-3 right-3 p-1.5 rounded-lg bg-surface-800 text-surface-400 hover:text-surface-200 hover:bg-surface-700 transition-colors" title="复制命令" onclick="navigator.clipboard?.writeText('bun run dev')">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
