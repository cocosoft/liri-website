---
---

<section id="desktop" class="section-padding relative">
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 via-surface-975 to-surface-950 pointer-events-none"></div>
  <div class="absolute top-1/2 right-0 w-80 h-80 bg-brand-500/5 blur-3xl rounded-full pointer-events-none"></div>

  <div class="section-container relative z-10">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">桌面客户端</span>
    </h2>
    <p class="text-surface-400 text-center mb-12 max-w-3xl mx-auto">
      Tauri v2 原生构建 · 147 个 TSX 组件 · 20+ 功能页面 · 完整的桌面体验
    </p>

    <!-- 模拟桌面界面 -->
    <div class="max-w-5xl mx-auto glass-card p-4 border-brand-500/20">
      <div class="rounded-xl overflow-hidden border border-surface-800/50 bg-surface-900/80">
        <!-- 模拟窗口标题栏 -->
        <div class="flex items-center gap-2 px-4 py-3 bg-surface-800/60 border-b border-surface-800/50">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-amber-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
          </div>
          <div class="flex-1 text-center">
            <span class="text-xs font-mono text-surface-500">Liri Desktop · Tauri v2</span>
          </div>
        </div>

        <!-- 模拟侧边栏 + 主内容 -->
        <div class="flex h-64 sm:h-80">
          <!-- 侧边栏导航（移动端隐藏） -->
          <div class="hidden sm:block w-40 lg:w-48 bg-surface-900/60 border-r border-surface-800/50 p-3 space-y-1 overflow-y-auto">
            {['聊天', 'AI 模型', '知识库', '记忆管理', '技能市场', 'MCP 市场', '定时任务', '成本中心', 'Buddy 人格', '系统设置'].map((item, i) => (
              <div class={`flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-mono ${i === 0 ? 'bg-brand-500/10 text-brand-300 border border-brand-500/20' : 'text-surface-400 hover:text-surface-200 hover:bg-surface-800/50'} transition-colors cursor-default`}>
                <span class="w-1.5 h-1.5 rounded-full bg-current opacity-50"></span>
                {item}
              </div>
            ))}
          </div>

          <!-- 主内容区 -->
          <div class="flex-1 p-3 sm:p-5">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-brand-500/20 flex items-center justify-center text-lg">💬</div>
              <div>
                <div class="text-sm font-bold text-surface-200">聊天面板</div>
                <div class="text-xs text-surface-500">Liri · 玲珑鸟</div>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex justify-start">
                <div class="max-w-xs p-3 rounded-2xl bg-surface-800/60 border border-surface-800/50 text-sm text-surface-300">
                  你好！我是 Liri，有什么需要帮忙的吗？
                </div>
              </div>
              <div class="flex justify-end">
                <div class="max-w-xs p-3 rounded-2xl bg-brand-500/10 border border-brand-500/20 text-sm text-surface-200">
                  帮我分析一下这个项目的数据
                </div>
              </div>
              <div class="flex justify-start">
                <div class="max-w-xs p-3 rounded-2xl bg-surface-800/60 border border-surface-800/50 text-sm text-surface-300">
                  好的，正在分析中...
                </div>
              </div>
            </div>
            <div class="mt-3 p-3 rounded-xl bg-surface-800/40 border border-surface-800/50 flex items-center gap-2">
              <div class="flex-1 h-8 rounded-lg bg-surface-800/60 border border-surface-800/50 px-3 flex items-center">
                <span class="text-xs text-surface-500">输入消息，按 Enter 发送...</span>
              </div>
              <div class="w-8 h-8 rounded-lg bg-brand-500/20 flex items-center justify-center">
                <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 功能列表 -->
    <div class="mt-10 max-w-5xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { icon: '💬', label: '聊天面板', desc: '即时对话' },
        { icon: '🤖', label: 'AI 模型管理', desc: '多模型切换' },
        { icon: '📚', label: '知识库', desc: '文件检索' },
        { icon: '🧠', label: '记忆管理', desc: '历史回顾' },
        { icon: '⏰', label: '定时任务', desc: 'Cron 引擎' },
        { icon: '🔌', label: 'MCP 市场', desc: '无限扩展' },
        { icon: '💰', label: '成本中心', desc: '用量透明' },
        { icon: '🎭', label: 'Buddy 人格', desc: '伙伴系统' },
      ].map((f) => (
        <div class="glass-card p-4 text-center hover:border-brand-500/30 transition-all duration-300">
          <div class="text-xl mb-1">{f.icon}</div>
          <div class="text-sm font-semibold text-surface-200">{f.label}</div>
          <div class="text-xs text-surface-500">{f.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>
