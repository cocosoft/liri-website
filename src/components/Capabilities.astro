<section id="capabilities" class="section-padding relative">
  <!-- 背景装饰 -->
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 via-surface-975 to-surface-950 pointer-events-none"></div>

  <div class="section-container relative z-10">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">核心能力</span>
    </h2>
    <p class="text-surface-400 text-center mb-16 max-w-2xl mx-auto">
      六大差异化能力，每一项都是真实工程实力，不是 PPT 功能
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {capabilities.map((cap, index) => (
        <div
          class="glass-card p-6 group hover:border-brand-500/30 transition-all duration-500 hover:-translate-y-1 glow"
          style={`animation: fade-in-up .6s ease-out ${index * 0.1}s both;`}
        >
          <div class="flex items-center justify-between mb-4">
            <div class="text-3xl group-hover:scale-110 transition-transform duration-300">{cap.icon}</div>
            <span class="px-2.5 py-0.5 rounded-full text-xs font-mono bg-brand-500/10 text-brand-400 border border-brand-500/20">
              {cap.highlight}
            </span>
          </div>
          <h3 class="text-lg font-bold text-surface-100 mb-2">{cap.title}</h3>
          <p class="text-surface-400 text-sm mb-4 leading-relaxed">{cap.description}</p>
          <ul class="space-y-1.5">
            {cap.details.map((detail) => (
              <li class="flex items-center gap-2 text-sm text-surface-500">
                <svg class="w-3.5 h-3.5 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {detail}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>