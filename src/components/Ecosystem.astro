---
---

<section id="ecosystem" class="section-padding relative">
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 via-surface-975 to-surface-950 pointer-events-none"></div>

  <div class="section-container relative z-10">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">生态市场</span>
    </h2>
    <p class="text-surface-400 text-center mb-12 max-w-3xl mx-auto">
      MCP 市场 + ClawHub + 技能市场 + 插件市场 = 无限扩展的 Liri 生态
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
      <!-- MCP 市场 -->
      <div class="glass-card p-6 text-center hover:border-brand-500/30 transition-all duration-500 hover:-translate-y-1">
        <div class="text-3xl mb-3">🔌</div>
        <h3 class="text-base font-bold text-surface-100 mb-2">MCP 市场</h3>
        <p class="text-xs text-surface-400 mb-4">Model Context Protocol 服务市场</p>
        <div class="space-y-1.5">
          {['GitHub MCP', '文件系统 MCP', '数据库 MCP', 'Web 搜索 MCP', '自定义 MCP 服务端'].map((item) => (
            <div class="flex items-center gap-2 text-xs text-surface-500">
              <svg class="w-3 h-3 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </div>
          ))}
        </div>
      </div>

      <!-- ClawHub -->
      <div class="glass-card p-6 text-center hover:border-brand-500/30 transition-all duration-500 hover:-translate-y-1">
        <div class="text-3xl mb-3">🦀</div>
        <h3 class="text-base font-bold text-surface-100 mb-2">ClawHub 市场</h3>
        <p class="text-xs text-surface-400 mb-4">主流 MCP 生态集中接入</p>
        <div class="space-y-1.5">
          {['ClawHub Registry Hub', '一键安装 MCP 服务', '版本管理与更新', '依赖自动解析', '社区评分系统'].map((item) => (
            <div class="flex items-center gap-2 text-xs text-surface-500">
              <svg class="w-3 h-3 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </div>
          ))}
        </div>
      </div>

      <!-- 技能市场 -->
      <div class="glass-card p-6 text-center hover:border-brand-500/30 transition-all duration-500 hover:-translate-y-1">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="text-base font-bold text-surface-100 mb-2">技能市场</h3>
        <p class="text-xs text-surface-400 mb-4">条件触发式技能编排系统</p>
        <div class="space-y-1.5">
          {['Skill Hub 集中仓库', '条件触发编排', '技能组合与匹配', '60+ 内置技能', '自定义技能 SDK'].map((item) => (
            <div class="flex items-center gap-2 text-xs text-surface-500">
              <svg class="w-3 h-3 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </div>
          ))}
        </div>
      </div>

      <!-- 插件市场 -->
      <div class="glass-card p-6 text-center hover:border-brand-500/30 transition-all duration-500 hover:-translate-y-1">
        <div class="text-3xl mb-3">🧩</div>
        <h3 class="text-base font-bold text-surface-100 mb-2">插件市场</h3>
        <p class="text-xs text-surface-400 mb-4">插件 SDK 全生命周期管理</p>
        <div class="space-y-1.5">
          {['插件 SDK + CLI', '生命周期钩子', '4 种构建变体', '三级延迟加载', 'DI 容器集成'].map((item) => (
            <div class="flex items-center gap-2 text-xs text-surface-500">
              <svg class="w-3 h-3 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
