---
---

<section id="brain" class="section-padding relative">
  <!-- 背景装饰 -->
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 via-surface-975 to-surface-950 pointer-events-none"></div>
  <div class="absolute top-1/4 right-0 w-96 h-96 bg-cyan-500/5 blur-3xl rounded-full pointer-events-none"></div>

  <div class="section-container relative z-10">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">外脑系统</span>
    </h2>
    <p class="text-surface-400 text-center mb-16 max-w-3xl mx-auto">
      文件管理系统 → 知识库系统 → 记忆系统：三层流水线，构建永不遗忘的外脑
    </p>

    <!-- 三层流水线 -->
    <div class="max-w-5xl mx-auto">
      <!-- 第一层：文件管理系统 -->
      <div class="glass-card p-6 text-center group hover:border-cyan-500/30 transition-all duration-500">
        <div class="flex items-center justify-center gap-2 mb-3">
          <span class="px-3 py-1 rounded-full text-xs font-mono bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">
            第1层：原料商
          </span>
        </div>
        <h3 class="text-xl font-bold text-surface-100 mb-2">文件管理系统</h3>
        <p class="text-surface-400 text-sm mb-4">所有知识的原材料入口</p>
        <div class="flex flex-wrap justify-center gap-2">
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">拖拽上传</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">目录树</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">多格式支持</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">WebFetch 下载</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">多 Tab 编辑</span>
        </div>
      </div>

      <!-- 连接箭头 -->
      <div class="flex justify-center py-2">
        <svg class="w-5 h-5 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>

      <!-- 第二层：知识库系统 -->
      <div class="glass-card p-6 text-center group hover:border-brand-500/30 transition-all duration-500">
        <div class="flex items-center justify-center gap-2 mb-3">
          <span class="px-3 py-1 rounded-full text-xs font-mono bg-brand-500/10 text-brand-400 border border-brand-500/20">
            第2层：加工厂
          </span>
        </div>
        <h3 class="text-xl font-bold text-surface-100 mb-2">知识库系统</h3>
        <p class="text-surface-400 text-sm mb-4">将原始文件加工成可检索的知识</p>
        <div class="flex flex-wrap justify-center gap-2">
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">自动摄取</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">混合搜索</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">智能摘要</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">语义检索</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">关键词索引</span>
        </div>
      </div>

      <!-- 连接箭头 -->
      <div class="flex justify-center py-2">
        <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>

      <!-- 第三层：记忆系统 -->
      <div class="glass-card p-6 text-center group hover:border-purple-500/30 transition-all duration-500">
        <div class="flex items-center justify-center gap-2 mb-3">
          <span class="px-3 py-1 rounded-full text-xs font-mono bg-purple-500/10 text-purple-400 border border-purple-500/20">
            第3层：神经中枢
          </span>
        </div>
        <h3 class="text-xl font-bold text-surface-100 mb-2">记忆系统</h3>
        <p class="text-surface-400 text-sm mb-4">让知识成为 AI 的长期记忆</p>
        <div class="flex flex-wrap justify-center gap-2">
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">短期→长期记忆</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">记忆搜索</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">记忆清洗</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">DumpSession</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800/60 text-surface-300 text-xs font-mono border border-surface-700/50">上下文注入</span>
        </div>
      </div>
    </div>

    <!-- 分隔：自进化架构 -->
    <div class="mt-24">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
        <span class="gradient-text">自进化架构</span>
      </h2>
      <p class="text-surface-400 text-center mb-16 max-w-3xl mx-auto">
        四层进化 + 梦境引擎驱动，系统在每一次交互和空闲中持续自我优化
      </p>

      <!-- 四层进化 -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto mb-12">
        <div class="glass-card p-5 text-center hover:border-cyan-500/30 transition-all duration-300">
          <div class="text-xs font-mono text-cyan-400 mb-2">E1: 知识层</div>
          <div class="text-sm text-surface-300 font-semibold mb-1">知识库持续更新</div>
          <div class="text-xs text-surface-500">新文档自动摄取 → 摘要更新 → 索引重建</div>
        </div>
        <div class="glass-card p-5 text-center hover:border-brand-500/30 transition-all duration-300">
          <div class="text-xs font-mono text-brand-400 mb-2">E2: 记忆层</div>
          <div class="text-sm text-surface-300 font-semibold mb-1">记忆自动优化</div>
          <div class="text-xs text-surface-500">短期→长期 → 记忆清洗 → 相关性重排序</div>
        </div>
        <div class="glass-card p-5 text-center hover:border-purple-500/30 transition-all duration-300">
          <div class="text-xs font-mono text-purple-400 mb-2">E3: 路由层</div>
          <div class="text-sm text-surface-300 font-semibold mb-1">路由策略进化</div>
          <div class="text-xs text-surface-500">成功率统计 → 延迟分析 → 成本优化</div>
        </div>
        <div class="glass-card p-5 text-center hover:border-amber-500/30 transition-all duration-300">
          <div class="text-xs font-mono text-amber-400 mb-2">E4: 执行层</div>
          <div class="text-sm text-surface-300 font-semibold mb-1">执行策略进化</div>
          <div class="text-xs text-surface-500">工具使用模式学习 → 策略组合优化</div>
        </div>
      </div>

      <!-- 梦境引擎 -->
      <div class="max-w-3xl mx-auto glass-card p-8 text-center border-amber-500/20">
        <div class="text-4xl mb-4">🌙</div>
        <h3 class="text-xl font-bold text-surface-100 mb-3">DreamEngine 梦境引擎</h3>
        <p class="text-surface-400 text-sm mb-6">
          当系统空闲时，自动进入梦境模式——整理记忆、优化知识、生成洞察。
          就像人类的睡眠，在你不使用时，Liri 在默默地变聪明。
        </p>
        <div class="grid grid-cols-3 gap-4">
          <div class="p-4 rounded-xl bg-surface-800/40 border border-surface-800/50">
            <div class="text-2xl mb-1">🌅</div>
            <div class="text-sm font-semibold text-surface-200 mb-1">Light 梦境</div>
            <div class="text-xs text-surface-500">轻度记忆整理</div>
          </div>
          <div class="p-4 rounded-xl bg-surface-800/40 border border-surface-800/50">
            <div class="text-2xl mb-1">🌊</div>
            <div class="text-sm font-semibold text-surface-200 mb-1">Deep 梦境</div>
            <div class="text-xs text-surface-500">深度知识重组</div>
          </div>
          <div class="p-4 rounded-xl bg-surface-800/40 border border-surface-800/50">
            <div class="text-2xl mb-1">💫</div>
            <div class="text-sm font-semibold text-surface-200 mb-1">REM 梦境</div>
            <div class="text-xs text-surface-500">洞察生成优化</div>
          </div>
        </div>
      </div>

      <!-- PDCA 自迭代 -->
      <div class="max-w-3xl mx-auto mt-6 glass-card p-8 text-center border-green-500/20">
        <div class="text-4xl mb-4">🔄</div>
        <h3 class="text-xl font-bold text-surface-100 mb-3">PDCA 自迭代闭环</h3>
        <p class="text-surface-400 text-sm mb-6">
          对于长程任务，Liri 自动执行 Plan-Do-Check-Act 循环：
          分解任务 → 执行步骤 → 评审结果 → 修正方案，直到任务完美完成。
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="p-3 rounded-xl bg-green-500/10 border border-green-500/20">
            <div class="text-sm font-semibold text-green-300">Plan</div>
            <div class="text-xs text-surface-500 mt-1">自动分解</div>
          </div>
          <div class="p-3 rounded-xl bg-brand-500/10 border border-brand-500/20">
            <div class="text-sm font-semibold text-brand-300">Do</div>
            <div class="text-xs text-surface-500 mt-1">逐步执行</div>
          </div>
          <div class="p-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
            <div class="text-sm font-semibold text-amber-300">Check</div>
            <div class="text-xs text-surface-500 mt-1">自动评审</div>
          </div>
          <div class="p-3 rounded-xl bg-cyan-500/10 border border-cyan-500/20">
            <div class="text-sm font-semibold text-cyan-300">Act</div>
            <div class="text-xs text-surface-500 mt-1">自动修正</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
