---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-surface-800/50">
  <div class="section-container py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- 版权 -->
      <div class="flex items-center gap-3">
        <span class="text-surface-500 text-sm">
          &copy; {currentYear} OpenLiri. MIT License.
        </span>
      </div>

      <!-- 链接 -->
      <div class="flex items-center gap-6">
        <a href="https://github.com/cocosoft/liri-website" target="_blank" rel="noopener noreferrer" class="text-surface-500 hover:text-surface-300 transition-colors text-sm">
          GitHub
        </a>
        <a href="https://github.com/cocosoft/liri-website/issues" target="_blank" rel="noopener noreferrer" class="text-surface-500 hover:text-surface-300 transition-colors text-sm">
          反馈
        </a>
        <a href="https://github.com/cocosoft/liri-website/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-surface-500 hover:text-surface-300 transition-colors text-sm">
          MIT License
        </a>
      </div>
    </div>
  </div>
</footer>
