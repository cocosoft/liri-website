---
// 语音能力数据
const features = [
  {
    title: '语音输入',
    desc: 'STT 语音转文字，支持多平台',
    icon: '🎤',
    color: 'from-cyan-500 to-blue-500',
    platforms: ['Web Speech API', '百度语音', 'Azure Speech', '自研引擎'],
  },
  {
    title: '语音输出',
    desc: 'TTS 文字转语音，支持多种音色',
    icon: '🔊',
    color: 'from-brand-500 to-orange-500',
    platforms: ['Edge TTS', 'OpenAI TTS', '自研引擎', '音色定制'],
  },
  {
    title: '实时交互',
    desc: '流式语音实时对话，低延迟体验',
    icon: '⚡',
    color: 'from-purple-500 to-pink-500',
    platforms: ['WebSocket 流式', '双工通信', '打断支持', '静默检测'],
  },
  {
    title: '多平台适配',
    desc: '桌面/CLI/移动端统一语音体验',
    icon: '📱',
    color: 'from-emerald-500 to-teal-500',
    platforms: ['Tauri 桌面', 'CLI 终端', 'Web 应用', '移动端适配'],
  },
];
---

<section id="voice" class="section-padding relative">
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 via-surface-975 to-surface-950 pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[400px] h-[400px] bg-cyan-500/5 blur-3xl rounded-full pointer-events-none"></div>

  <div class="section-container relative z-10">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">语音交互</span>
    </h2>
    <p class="text-surface-400 text-center mb-12 max-w-3xl mx-auto">
      不只是打字——说出你的需求，Liri 听懂、执行、回答
    </p>

    <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-5">
      {features.map((f, index) => (
        <div
          class="glass-card p-6 group hover:border-brand-500/30 transition-all duration-500 hover:-translate-y-1"
          style={`animation: fade-in-up .5s ease-out ${index * 0.12}s both;`}>
          <div class="flex items-center gap-4 mb-4">
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${f.color} flex items-center justify-center text-xl
              group-hover:scale-110 transition-transform duration-300 shadow-lg`}>
              {f.icon}
            </div>
            <div>
              <h3 class="text-base font-bold text-surface-100">{f.title}</h3>
              <p class="text-xs text-surface-400">{f.desc}</p>
            </div>
          </div>
          <div class="space-y-1.5">
            {f.platforms.map((pf) => (
              <div class="flex items-center gap-2 text-xs text-surface-400">
                <svg class="w-3 h-3 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {pf}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 适用场景 -->
    <div class="mt-8 max-w-2xl mx-auto glass-card p-5 text-center border-cyan-500/20">
      <p class="text-surface-400 text-sm">
        免提操作 · 多任务场景 · 无障碍辅助 · 语音快捷指令 ·
        <span class="text-brand-400 font-semibold">随时随地，说出即执行</span>
      </p>
    </div>
  </div>
</section>
