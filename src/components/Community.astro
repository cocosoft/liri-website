---
---

<section id="community" class="section-padding relative">
  <div class="section-container">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      <span class="gradient-text">开源 · 社区</span>
    </h2>
    <p class="text-surface-400 text-center mb-16 max-w-2xl mx-auto">
      Liri 是开源项目，我们欢迎每一位贡献者
    </p>

    <div class="max-w-3xl mx-auto grid sm:grid-cols-2 gap-6">
      <!-- GitHub -->
      <a href="https://github.com/cocosoft/liri" target="_blank" rel="noopener noreferrer" class="glass-card p-8 text-center group hover:border-brand-500/30 transition-all duration-300 glow">
        <div class="w-14 h-14 rounded-xl bg-surface-800 flex items-center justify-center mx-auto mb-5 group-hover:bg-brand-500/10 transition-colors">
          <svg class="w-7 h-7 text-surface-300 group-hover:text-brand-400 transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-surface-100 mb-2 group-hover:text-brand-400 transition-colors">GitHub</h3>
        <p class="text-surface-400 text-sm mb-4">在 GitHub 上关注项目，提交 Issue 或 PR</p>
        <span class="inline-flex items-center gap-1.5 text-sm text-brand-400 font-mono">
          github.com/cocosoft/liri
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </span>
      </a>

      <!-- 社区 -->
      <div class="glass-card p-8 text-center group hover:border-brand-500/30 transition-all duration-300">
        <div class="w-14 h-14 rounded-xl bg-surface-800 flex items-center justify-center mx-auto mb-5 group-hover:bg-brand-500/10 transition-colors">
          <svg class="w-7 h-7 text-surface-300 group-hover:text-brand-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-surface-100 mb-2">加入社区</h3>
        <p class="text-surface-400 text-sm mb-4">与开发者交流，获取最新动态</p>
        <div class="flex items-center justify-center gap-3">
          <span class="px-3 py-1 rounded-lg bg-surface-800 text-surface-400 text-sm font-mono border border-surface-700/50">Discord</span>
          <span class="px-3 py-1 rounded-lg bg-surface-800 text-surface-400 text-sm font-mono border border-surface-700/50">微信群</span>
        </div>
      </div>
    </div>
  </div>
</section>
